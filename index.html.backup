<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>超黄体系 · 每日复盘</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Noto Sans SC', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    colors: {
                        bg: '#0a0e1a',
                        card: '#111827',
                        cardHover: '#1a2235',
                        border: '#1f2937',
                        gold: '#fbbf24',
                        red: '#ef4444',
                        green: '#22c55e',
                        amber: '#f59e0b',
                        rose: '#fb7185',
                        cyan: '#06b6d4',
                    }
                }
            }
        }
    </script>
    <style>
        body { background: #0a0e1a; color: #e2e8f0; font-family: 'Noto Sans SC', sans-serif; }
        .glass { background: rgba(17,24,39,0.85); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.05); }
        .card-glow { box-shadow: 0 0 20px rgba(251,191,36,0.05); }
        .pulse-gold { animation: pulseGold 2s infinite; }
        @keyframes pulseGold { 0%,100% { box-shadow: 0 0 5px rgba(251,191,36,0.3); } 50% { box-shadow: 0 0 20px rgba(251,191,36,0.6); } }
        .shimmer { background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent); background-size: 200% 100%; animation: shimmer 2s infinite; }
        @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
        .tab-active { border-bottom: 2px solid #fbbf24; color: #fbbf24; }
        .limit-up { color: #ef4444; }
        .limit-down { color: #22c55e; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0a0e1a; }
        ::-webkit-scrollbar-thumb { background: #1f2937; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #374151; }
    </style>
</head>
<body class="min-h-screen">
    <!-- 顶部导航 -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass">
        <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-gradient-to-br from-gold to-amber rounded flex items-center justify-center">
                    <i class="fas fa-chart-line text-black text-sm"></i>
                </div>
                <h1 class="font-bold text-lg tracking-wide">超黄体系 <span class="text-gold">·</span> 每日复盘</h1>
            </div>
            <div class="flex items-center gap-4">
                <select id="dateSelector" class="bg-card border border-border rounded px-3 py-1.5 text-sm focus:outline-none focus:border-gold">
                    <option value="2026-05-15">2026-05-15 周五</option>
                </select>
                <div id="marketTemp" class="px-3 py-1 rounded text-xs font-medium bg-amber-500/20 text-amber-400 border border-amber-500/30">
                    ⚠️ 分歧
                </div>
            </div>
        </div>
    </nav>

    <!-- 主内容 -->
    <main class="pt-16 pb-8 px-4 max-w-7xl mx-auto">
        <!-- 核心数据卡片 -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
            <div class="glass rounded-lg p-4 card-glow">
                <div class="text-xs text-gray-400 mb-1">涨停数</div>
                <div class="text-2xl font-bold font-mono limit-up">72<span class="text-xs text-gray-500 ml-1">只</span></div>
                <div class="text-xs text-gray-500 mt-1">非ST: 54只</div>
            </div>
            <div class="glass rounded-lg p-4 card-glow">
                <div class="text-xs text-gray-400 mb-1">跌停数</div>
                <div class="text-2xl font-bold font-mono limit-down">11<span class="text-xs text-gray-500 ml-1">只</span></div>
            </div>
            <div class="glass rounded-lg p-4 card-glow">
                <div class="text-xs text-gray-400 mb-1">最高连板</div>
                <div class="text-2xl font-bold font-mono text-gold">6<span class="text-xs text-gray-500 ml-1">板</span></div>
                <div class="text-xs text-gray-500 mt-1">蒙娜丽莎</div>
            </div>
            <div class="glass rounded-lg p-4 card-glow">
                <div class="text-xs text-gray-400 mb-1">上证涨跌</div>
                <div class="text-2xl font-bold font-mono limit-down">-1.02<span class="text-xs text-gray-500 ml-1">%</span></div>
                <div class="text-xs text-gray-500 mt-1">4,135.39</div>
            </div>
        </div>

        <!-- Tab 导航 -->
        <div class="flex gap-6 border-b border-border mb-6 overflow-x-auto">
            <button onclick="switchTab('wind')" id="tab-wind" class="tab-btn pb-3 text-sm font-medium text-gray-400 border-b-2 border-transparent hover:text-gray-200 whitespace-nowrap">
                <i class="fas fa-wind mr-1.5"></i>风向早报
            </button>
            <button onclick="switchTab('morning')" id="tab-morning" class="tab-btn pb-3 text-sm font-medium text-gray-400 border-b-2 border-transparent hover:text-gray-200 whitespace-nowrap">
                <i class="fas fa-sun mr-1.5"></i>早盘策略
            </button>
            <button onclick="switchTab('firstboard')" id="tab-firstboard" class="tab-btn pb-3 text-sm font-medium text-gray-400 border-b-2 border-transparent hover:text-gray-200 whitespace-nowrap">
                <i class="fas fa-star mr-1.5"></i>首板策略
            </button>
            <button onclick="switchTab('noon')" id="tab-noon" class="tab-btn pb-3 text-sm font-medium text-gray-400 border-b-2 border-transparent hover:text-gray-200 whitespace-nowrap">
                <i class="fas fa-cloud-sun mr-1.5"></i>午间小结
            </button>
            <button onclick="switchTab('review')" id="tab-review" class="tab-btn pb-3 text-sm font-medium text-gray-400 border-b-2 border-transparent hover:text-gray-200 whitespace-nowrap">
                <i class="fas fa-moon mr-1.5"></i>深度复盘
            </button>
            <button onclick="switchTab('youthu')" id="tab-youthu" class="tab-btn pb-3 text-sm font-medium text-gray-400 border-b-2 border-transparent hover:text-gray-200 whitespace-nowrap">
                <i class="fas fa-dragon mr-1.5"></i>游资复盘
            </button>
            <button onclick="switchTab('firstboard')" id="tab-firstboard" class="tab-btn pb-3 text-sm font-medium text-gray-400 border-b-2 border-transparent hover:text-gray-200 whitespace-nowrap">
                <i class="fas fa-star mr-1.5"></i>首板策略
            </button>
            <button onclick="switchTab('history')" id="tab-history" class="tab-btn pb-3 text-sm font-medium text-gray-400 border-b-2 border-transparent hover:text-gray-200 whitespace-nowrap">
                <i class="fas fa-archive mr-1.5"></i>历史归档
            </button>
        </div>

        <!-- 风向早报内容 -->
        <div id="content-wind" class="tab-content">
            <div class="glass rounded-lg p-5 mb-5">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2 text-cyan-400">
                    <i class="fas fa-globe-americas"></i>
                    外围映射（精确到0.01%）
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4">
                    <div class="bg-card rounded p-3">
                        <div class="text-xs text-gray-400 mb-1">道指（美东5/14收盘）</div>
                        <div class="text-xl font-bold font-mono limit-down">-0.14%</div>
                        <div class="text-xs text-gray-500">49,693.20</div>
                    </div>
                    <div class="bg-card rounded p-3 border border-gold/20">
                        <div class="text-xs text-gray-400 mb-1">纳指 🔥历史新高</div>
                        <div class="text-xl font-bold font-mono limit-up">+1.20%</div>
                        <div class="text-xs text-gray-500">26,402.34</div>
                    </div>
                    <div class="bg-card rounded p-3 border border-gold/20">
                        <div class="text-xs text-gray-400 mb-1">标普500 🔥历史新高</div>
                        <div class="text-xl font-bold font-mono limit-up">+0.58%</div>
                        <div class="text-xs text-gray-500">7,444.25</div>
                    </div>
                </div>
                <div class="bg-card rounded p-3 mb-3">
                    <div class="text-xs text-gray-400 mb-2">热门科技股</div>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-sm">
                        <div class="flex justify-between"><span>英伟达</span><span class="limit-up font-mono">+2.30%</span></div>
                        <div class="flex justify-between"><span>美光科技</span><span class="limit-up font-mono">+4.83%</span></div>
                        <div class="flex justify-between"><span>谷歌</span><span class="limit-up font-mono">+3.95%</span></div>
                        <div class="flex justify-between"><span>Meta</span><span class="limit-up font-mono">+2.15%</span></div>
                    </div>
                </div>
                <div class="bg-card rounded p-3 mb-3">
                    <div class="text-xs text-gray-400 mb-2">中概股</div>
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-2 text-sm">
                        <div class="flex justify-between"><span>纳斯达克中国金龙</span><span class="limit-up font-mono">+3.89%</span></div>
                        <div class="flex justify-between"><span>金山云</span><span class="limit-up font-mono">+17.05%</span></div>
                        <div class="flex justify-between"><span>阿里巴巴</span><span class="limit-up font-mono">+8.18%</span></div>
                    </div>
                </div>
                <div class="bg-gold/10 border border-gold/20 rounded p-3">
                    <div class="text-gold font-bold text-sm mb-1">🔥 光通信/CPO（A股映射重点）</div>
                    <div class="text-xs text-gray-300">Coherent +7.95% · 康宁 +4.21% · Lumentum +3.14%</div>
                    <div class="text-xs text-gray-500 mt-1">→ AI算力需求驱动，光模块产业链持续高景气</div>
                </div>
            </div>

            <div class="glass rounded-lg p-5 mb-5">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2 text-cyan-400">
                    <i class="fas fa-newspaper"></i>
                    政策风向
                </h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-xs">
                        <thead>
                            <tr class="text-gray-400 border-b border-border">
                                <th class="pb-2 text-left">日期</th>
                                <th class="pb-2 text-left">政策/事件</th>
                                <th class="pb-2 text-left">来源</th>
                                <th class="pb-2 text-left">影响板块</th>
                                <th class="pb-2 text-center">时效</th>
                            </tr>
                        </thead>
                        <tbody class="text-gray-300">
                            <tr class="border-b border-border/50">
                                <td class="py-2 text-gray-400">05-15</td>
                                <td class="py-2">央行开展3000亿元买断式逆回购（6个月期）</td>
                                <td class="py-2 text-gray-400">央行公告</td>
                                <td class="py-2">流动性</td>
                                <td class="py-2 text-center"><span class="text-amber-400">⚠️常态化</span></td>
                            </tr>
                            <tr class="border-b border-border/50">
                                <td class="py-2 text-gray-400">05-14</td>
                                <td class="py-2">农业农村部修订《生猪产能综合调控实施方案》</td>
                                <td class="py-2 text-gray-400">农业农村部</td>
                                <td class="py-2">养殖</td>
                                <td class="py-2 text-center"><span class="text-green-400">✅今日生效</span></td>
                            </tr>
                            <tr class="border-b border-border/50">
                                <td class="py-2 text-gray-400">05-14</td>
                                <td class="py-2">蒙娜丽莎风险提示：参股公司并非英伟达供应商</td>
                                <td class="py-2 text-gray-400">公司公告</td>
                                <td class="py-2">半导体</td>
                                <td class="py-2 text-center"><span class="text-red-400">⚠️高标风险</span></td>
                            </tr>
                            <tr>
                                <td class="py-2 text-gray-400">05-14</td>
                                <td class="py-2">大唐发电7天6板后断板（跌2.31%）</td>
                                <td class="py-2 text-gray-400">市场数据</td>
                                <td class="py-2">电力</td>
                                <td class="py-2 text-center"><span class="text-red-400">🔴高标承压</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="glass rounded-lg p-5 mb-5">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2 text-gold">
                    <i class="fas fa-crosshairs"></i>
                    唯一主线锁定
                </h2>
                <div class="bg-gold/10 border border-gold/20 rounded-lg p-4 mb-3">
                    <div class="text-gold font-bold text-lg mb-2">🔥 预判今日NO.1：光通信/CPO</div>
                    <div class="text-sm text-gray-300 mb-2">
                        <strong>双驱动逻辑：</strong><br/>
                        ① 外围：美股光通信大涨（Coherent+7.95%，康宁+4.21%），纳指+1.2%创历史新高<br/>
                        ② 中概股金龙指数+3.89%，科技情绪全面回暖<br/>
                        ③ 电力板块高标断板，资金可能切换至科技线
                    </div>
                    <div class="text-xs text-gray-400">验证标准：09:25:30该板块出现 ≥2只一字板/秒板 → ✅锁定成功</div>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-2 text-xs text-gray-400">
                    <div class="bg-card rounded p-2 text-center">
                        <div class="text-red-400">❌ 电力/能源</div>
                        <div>高标大唐发电断板，排除</div>
                    </div>
                    <div class="bg-card rounded p-2 text-center">
                        <div class="text-red-400">❌ 大消费/养殖</div>
                        <div>涨停数仅7只，排除</div>
                    </div>
                    <div class="bg-card rounded p-2 text-center">
                        <div class="text-red-400">❌ 半导体</div>
                        <div>高标风险提示，排除</div>
                    </div>
                    <div class="bg-gold/10 rounded p-2 text-center border border-gold/20">
                        <div class="text-gold">✅ 光通信/CPO</div>
                        <div>外围映射最强，锁定</div>
                    </div>
                </div>
            </div>

            <div class="glass rounded-lg p-5">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2 text-amber-400">
                    <i class="fas fa-history"></i>
                    昨日涨停板块回顾
                </h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-xs">
                        <thead>
                            <tr class="text-gray-400 border-b border-border">
                                <th class="pb-2 text-left">板块</th>
                                <th class="pb-2 text-center">涨停数</th>
                                <th class="pb-2 text-left">最高标</th>
                                <th class="pb-2 text-left">今日关注</th>
                            </tr>
                        </thead>
                        <tbody class="text-gray-300">
                            <tr class="border-b border-border/50">
                                <td class="py-2 font-medium">电力/能源</td>
                                <td class="py-2 text-center font-mono text-gold">13只</td>
                                <td class="py-2">蒙娜丽莎5板</td>
                                <td class="py-2 text-gray-400">大唐发电断板，板块分化，关注补涨而非追高</td>
                            </tr>
                            <tr class="border-b border-border/50">
                                <td class="py-2 font-medium">大消费</td>
                                <td class="py-2 text-center font-mono">7只</td>
                                <td class="py-2">蒙娜丽莎5板</td>
                                <td class="py-2 text-gray-400">养殖政策催化，华统股份/天邦食品等昨日已涨停</td>
                            </tr>
                            <tr class="border-b border-border/50">
                                <td class="py-2 font-medium">半导体</td>
                                <td class="py-2 text-center font-mono">5只</td>
                                <td class="py-2">可川科技3板</td>
                                <td class="py-2 text-gray-400">外围科技股大涨映射，但高标有风险提示</td>
                            </tr>
                            <tr class="border-b border-border/50">
                                <td class="py-2 font-medium">机器人</td>
                                <td class="py-2 text-center font-mono">4只</td>
                                <td class="py-2">—</td>
                                <td class="py-2 text-gray-400">持续性待观察</td>
                            </tr>
                            <tr>
                                <td class="py-2 font-medium">周期/有色/化工</td>
                                <td class="py-2 text-center font-mono">4只</td>
                                <td class="py-2">—</td>
                                <td class="py-2 text-gray-400">环氧丙烷涨价（泰和新材）</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- 早盘策略内容 -->
        <div id="content-morning" class="tab-content hidden">
            <!-- 情绪定位 -->
            <div class="glass rounded-lg p-5 mb-5">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <i class="fas fa-thermometer-half text-amber-400"></i>
                    情绪定位
                </h2>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
                    <div class="bg-card rounded p-3 text-center">
                        <div class="text-xs text-gray-400">昨日涨停高开率</div>
                        <div class="text-xl font-bold font-mono text-red-400 mt-1">11.1%</div>
                        <div class="text-xs text-red-500/70">❄️ 低于30%</div>
                    </div>
                    <div class="bg-card rounded p-3 text-center">
                        <div class="text-xs text-gray-400">一字板/秒板爆量</div>
                        <div class="text-xl font-bold font-mono text-green-400 mt-1">0只</div>
                        <div class="text-xs text-green-500/70">✅ 爆率&lt;30%</div>
                    </div>
                    <div class="bg-card rounded p-3 text-center">
                        <div class="text-xs text-gray-400">量能达标率</div>
                        <div class="text-xl font-bold font-mono text-amber-400 mt-1">9/54</div>
                        <div class="text-xs text-amber-500/70">⚠️ 低于60%</div>
                    </div>
                    <div class="bg-card rounded p-3 text-center">
                        <div class="text-xs text-gray-400">竞价涨停家数</div>
                        <div class="text-xl font-bold font-mono text-red-400 mt-1">3家</div>
                        <div class="text-xs text-red-500/70">❄️ 低于30只</div>
                    </div>
                </div>
                <div class="bg-red-500/10 border border-red-500/20 rounded p-3 text-center">
                    <span class="text-red-400 font-bold">🌡️ 情绪定位：⚠️ 分歧</span>
                    <span class="text-gray-400 mx-2">|</span>
                    <span class="text-amber-400 font-bold">建议仓位：总仓≤3成，单标≤1成</span>
                </div>
            </div>

            <!-- 板块强度 -->
            <div class="glass rounded-lg p-5 mb-5">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <i class="fas fa-fire text-red-400"></i>
                    板块强度实况
                </h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-gray-400 text-xs border-b border-border">
                                <th class="pb-2 text-left">排名</th>
                                <th class="pb-2 text-left">板块名称</th>
                                <th class="pb-2 text-center">涨停数</th>
                                <th class="pb-2 text-left">最高标</th>
                                <th class="pb-2 text-left">板块判定</th>
                            </tr>
                        </thead>
                        <tbody class="text-xs">
                            <tr class="border-b border-border/50">
                                <td class="py-3 font-bold text-gold">TOP1</td>
                                <td class="py-3 font-medium">大消费</td>
                                <td class="py-3 text-center font-mono">4只</td>
                                <td class="py-3">蒙娜丽莎(5板)</td>
                                <td class="py-3"><span class="text-gold">🔥🔥 强势（身位龙+首板集群）</span></td>
                            </tr>
                            <tr class="border-b border-border/50">
                                <td class="py-3 font-bold text-gold">TOP2</td>
                                <td class="py-3 font-medium">电力/能源</td>
                                <td class="py-3 text-center font-mono">2只</td>
                                <td class="py-3">天富能源(1板)</td>
                                <td class="py-3"><span class="text-amber-400">🔥 活跃（身位龙明确）</span></td>
                            </tr>
                            <tr>
                                <td class="py-3 font-bold text-gold">TOP3</td>
                                <td class="py-3 font-medium">液冷/服务器</td>
                                <td class="py-3 text-center font-mono">2只</td>
                                <td class="py-3">金富科技(1板)</td>
                                <td class="py-3"><span class="text-amber-400">🔥 活跃（题材扩散）</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>


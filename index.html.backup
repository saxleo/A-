                <i class="fas fa-archive text-4xl text-gray-600 mb-4"></i>
                <h3 class="text-lg font-bold text-gray-400 mb-2">历史归档</h3>
                <p class="text-sm text-gray-500">每日复盘数据将自动归档于此</p>
                <p class="text-xs text-gray-600 mt-4">当前仅展示 2026-05-15 数据</p>
            </div>
        </div>
    </main>

    <!-- 底部 -->
    <footer class="border-t border-border mt-8 py-6 text-center">
        <div class="text-xs text-gray-500">
            <p>超黄体系 · 每日复盘网站</p>
            <p class="mt-1">数据来源: 问财CLI + 脚本A V10.2 + 新浪财经 | Generated by Kimi Claw</p>
            <p class="mt-1 text-gray-600">⚠️ 数据为第三方估算，仅供学习交流，不构成投资建议</p>
        </div>
    </footer>

    <script>
        // Tab切换
        function switchTab(tab) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.tab-btn').forEach(el => {
                el.classList.remove('text-gold', 'border-gold');
                el.classList.add('text-gray-400', 'border-transparent');
            });
            document.getElementById('content-' + tab).classList.remove('hidden');
            document.getElementById('tab-' + tab).classList.remove('text-gray-400', 'border-transparent');
            document.getElementById('tab-' + tab).classList.add('text-gold', 'border-gold');
            
            if (tab === 'review') {
                setTimeout(initCharts, 100);
            }
        }

        // 图表初始化
        function initCharts() {
            // 板块强度图
            const sectorChart = echarts.init(document.getElementById('sectorChart'));
            sectorChart.setOption({
                backgroundColor: 'transparent',
                grid: { left: '3%', right: '4%', bottom: '3%', top: '3%', containLabel: true },
                xAxis: { type: 'value', axisLine: { lineStyle: { color: '#374151' } }, axisLabel: { color: '#9ca3af', fontSize: 10 }, splitLine: { lineStyle: { color: '#1f2937' } } },
                yAxis: { type: 'category', data: ['新材料','文化传媒','电力/能源','半导体','大消费','氟化工','机器人'], axisLine: { lineStyle: { color: '#374151' } }, axisLabel: { color: '#e2e8f0', fontSize: 11 } },
                series: [{
                    type: 'bar',
                    data: [
                        { value: 9.6, itemStyle: { color: '#6b7280' } },
                        { value: 9.6, itemStyle: { color: '#6b7280' } },
                        { value: 9.6, itemStyle: { color: '#f59e0b' } },
                        { value: 16.0, itemStyle: { color: '#22c55e' } },
                        { value: 25.6, itemStyle: { color: '#f59e0b' } },
                        { value: 32.0, itemStyle: { color: '#f97316' } },
                        { value: 57.6, itemStyle: { color: '#ef4444' } }
                    ],
                    barWidth: '60%',
                    label: { show: true, position: 'right', color: '#e2e8f0', fontSize: 10, formatter: '{c}分' }
                }]
            });

            // 涨停时间分布图
            const timeChart = echarts.init(document.getElementById('timeChart'));
            timeChart.setOption({
                backgroundColor: 'transparent',
                grid: { left: '3%', right: '4%', bottom: '3%', top: '10%', containLabel: true },
                xAxis: { type: 'category', data: ['09:25一字', '09:30-10:00', '10:00-11:30', '13:00-14:00', '14:00-15:00'], axisLine: { lineStyle: { color: '#374151' } }, axisLabel: { color: '#9ca3af', fontSize: 10 } },
                yAxis: { type: 'value', axisLine: { lineStyle: { color: '#374151' } }, axisLabel: { color: '#9ca3af', fontSize: 10 }, splitLine: { lineStyle: { color: '#1f2937' } } },
                series: [{
                    type: 'bar',
                    data: [
                        { value: 8, itemStyle: { color: '#fbbf24' } },
                        { value: 42, itemStyle: { color: '#ef4444' } },
                        { value: 14, itemStyle: { color: '#f59e0b' } },
                        { value: 6, itemStyle: { color: '#22c55e' } },
                        { value: 2, itemStyle: { color: '#6b7280' } }
                    ],
                    barWidth: '50%',
                    label: { show: true, position: 'top', color: '#e2e8f0', fontSize: 10, formatter: '{c}只' }
                }]
            });
        }

        // 响应式
        window.addEventListener('resize', () => {
            const sectorChart = echarts.getInstanceByDom(document.getElementById('sectorChart'));
            const timeChart = echarts.getInstanceByDom(document.getElementById('timeChart'));
            if (sectorChart) sectorChart.resize();
            if (timeChart) timeChart.resize();
        });
    </script>
</body>
</html>